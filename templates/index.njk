<!DOCTYPE html>
<html lang="en">
<head>
  {% set pageTitle = "BlockRocket | Expert Blockchain Engineering & Web3 Consultancy" %}
  {% set pageDescription = "High-performance blockchain solutions for enterprise and startups. From smart contract auditing to full-stack Web3 engineering, we build production-ready systems." %}
  {% include "_partials/head.njk" %}
</head>
<body class="body" data-screen-label="Home">
  {% set isHome = true %}
  {% include "_partials/nav.njk" %}

  <div id="hero" class="section_hero">
    <div class="container">
      <div data-aos="fade-up" class="main-content">
        <div class="w-layout-vflex top-content-wrapper">
          <div class="eyebrow">{{ home.hero.eyebrow }}</div>
          <h1 class="heading-1">{{ home.hero.heading }}</h1>
          <div class="lead-text">
            <div class="lead-text centre">{{ home.hero.lead | spanBold | safe }}</div>
          </div>
        </div>
        <a href="#contact" class="primary-button w-button">{{ home.hero.cta }}</a>
      </div>
    </div>
    <img src="/images/blocks_1blocks.avif" loading="lazy" data-aos="fade-up" alt="" class="left-block">
    <img src="/images/blocks_1blocks.avif" loading="lazy" data-aos="fade-up" alt="" class="right-block">
    <div class="hero-blur"></div>
  </div>

  <div id="about" class="section_about">
    <div class="container">
      <div class="flex-grid">
        <div data-aos="fade-up" class="left-col-wrapper">
          <div class="module-eyebrow"><img src="/images/icon.svg" loading="lazy" width="10.392416000366211" height="12" alt="" class="icon">
            <div class="green-eyebrow">{{ home.about.eyebrow }}</div>
          </div>
          <div class="h2-style">{{ home.about.heading }}</div>
          <div class="w-layout-vflex lead-text">
            {% for para in home.about.paragraphs %}
            <p class="body-regular left">{{ para | bodyBold | safe }}</p>
            {% endfor %}
          </div>
        </div>
        <img data-aos="fade-up" class="image" src="/images/nft-img_1nft-img.avif" alt="{{ home.about.imageAlt }}" sizes="(max-width: 1659px) 100vw, 1659px" loading="lazy" srcset="/images/nft-img_1-p-500.avif 500w, /images/nft-img_1nft-img.avif 1659w">
      </div>
    </div>
    <div class="container">
      <div class="flex-grid">
        <img data-aos="fade-up" class="image" src="/images/manchester_1manchester.avif" alt="{{ home.aboutHistory.imageAlt }}" sizes="(max-width: 1106px) 100vw, 1106px" id="w-node-eac2862a-6122-f9a0-c1ec-77d6ff313d49-f86bc39c" loading="lazy" srcset="/images/manchester_1-p-500.avif 500w, /images/manchester_1manchester.avif 1106w">
        <div data-aos="fade-up" class="left-col-wrapper">
          <div class="module-eyebrow"><img src="/images/icon.svg" loading="lazy" width="10.392416000366211" height="12" alt="" class="icon">
            <div class="green-eyebrow">{{ home.aboutHistory.eyebrow }}</div>
          </div>
          <div class="w-layout-vflex lead-text">
            {% for para in home.aboutHistory.paragraphs %}
            <p class="body-regular left">{{ para | bodyBold | safe }}</p>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    <img src="/images/half-blocks-left.png" loading="lazy" data-aos="fade-up" alt="" class="left-half-block">
    <img src="/images/half-blocks-right.png" loading="lazy" data-aos="fade-up" alt="" class="right-half-block">
  </div>

  {# OUR APPROACH — hidden, may restore later
  <div class="section_approach">
    <div class="container approach">
      <div data-aos="fade-up" class="header-wrapper">
        <div class="module-eyebrow"><img src="/images/icon.svg" loading="lazy" width="10.392416000366211" height="12" alt="" class="icon">
          <div class="green-eyebrow">{{ home.approach.eyebrow }}</div>
        </div>
        <h2 class="h2-style">{{ home.approach.heading }}</h2>
        <div class="w-layout-vflex lead-text">
          <p class="body-regular left">{{ home.approach.lead }}</p>
        </div>
      </div>
      <div class="_3-col-wrapper">
        {% for step in home.approach.steps %}
        {% if loop.index == 1 %}
        <div data-aos="fade-up" class="w-layout-hflex card-wrapper{{ ' ' + step.wrapperClass if step.wrapperClass }}">
        {% else %}
        <div data-aos-delay="{{ (loop.index - 1) * 200 }}" data-aos="fade-up" class="w-layout-hflex card-wrapper{{ ' ' + step.wrapperClass if step.wrapperClass }}">
        {% endif %}
          <div class="col-card"><img src="/images/{{ step.icon }}" loading="lazy" width="81" height="79" alt="{{ step.iconAlt }}" class="card-img">
            <div class="card-content-wrapper">
              <h3 class="card-header">{{ step.number }}. {{ step.title }}</h3>
              <div class="body-regular left small">{{ step.body }}</div>
            </div>
          </div>
        </div>
        {% if loop.index == 1 %}
        <img src="/images/connector.svg" loading="lazy" width="169.5" height="44.00000762939453" alt="" data-aos-delay="100" data-aos="fade-up" class="connector">
        {% elif loop.index == 2 %}
        <img src="/images/connector_1.svg" loading="lazy" width="169.5" height="44.00000762939453" alt="" data-aos-delay="300" data-aos="fade-up" class="connector">
        {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
  #}

  <div id="services" data-aos="fade-up" class="section_services">
    <div class="container services">
      <div data-aos="fade-up" class="header-wrapper">
        <div class="module-eyebrow"><img src="/images/black-icon.svg" loading="lazy" width="10.392416000366211" height="12" alt="" class="icon">
          <div class="black-eyebrow">{{ home.services.eyebrow }}</div>
        </div>
        <h2 class="h2-style black">{{ home.services.heading }}</h2>
        <div class="w-layout-vflex lead-text">
          <p class="body-regular left black">{{ home.services.lead }}</p>
        </div>
      </div>
      <div class="card-grid">
        {% for svc in home.services.items %}
        <div data-aos="fade-up" class="card">
          <div class="img-and-header"><img src="/images/{{ svc.icon }}" loading="lazy" width="109" height="106" alt="{{ svc.iconAlt }}" class="image-5">
            <div class="card-header-wrapper">
              <div class="service-card-title">{{ svc.title }}</div>
            </div>
          </div>
          <div class="card-header-wrapper">
            <div class="subtitle black">{{ svc.subtitle }}</div>
            <div class="body-regular left black">{{ svc.body }}</div>
          </div>
          <div class="card-list-wrapper">
            <div class="subtitle black">{{ svc.listHeading }}</div>
            <ul role="list" class="list w-list-unstyled">
              {% for item in svc.listItems %}
              <li class="list-item"><div class="list-text">{{ item }}</div></li>
              {% endfor %}
            </ul>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div id="case-studies" class="section_case-studies">
    <div class="container approach">
      <div data-aos="fade-up" class="header-wrapper">
        <div class="module-eyebrow"><img src="/images/icon.svg" loading="lazy" width="10.392416000366211" height="12" alt="" class="icon">
          <div class="green-eyebrow">{{ home.caseStudies.eyebrow }}</div>
        </div>
        <h2 class="h2-style">{{ home.caseStudies.heading }}</h2>
        <div class="w-layout-vflex lead-text">
          <p class="body-regular left">{{ home.caseStudies.lead }}</p>
        </div>
      </div>
      <div class="case-studies-grid">
        <div data-aos="fade-up" id="w-node-_66edd9a2-d3e1-4155-24f6-473270acd461-f86bc39c" class="w-layout-hflex case-study-card one">
          <div class="cs-wrapper"><div class="w-layout-hflex tag-wrapper"><div class="tag"><div class="text">ERC-721</div></div><div class="tag"><div class="text">ERC-721</div></div></div></div>
        </div>
        <div data-aos="fade-up" class="w-layout-hflex case-study-card">
          <div class="cs-wrapper three"><div class="w-layout-hflex tag-wrapper"><div class="tag"><div class="text">ERC-721</div></div><div class="tag"><div class="text">ERC-721</div></div></div></div>
        </div>
        <div data-aos="fade-up" class="w-layout-hflex case-study-card">
          <div class="cs-wrapper five"><div class="w-layout-hflex tag-wrapper"><div class="tag"><div class="text">ERC-721</div></div><div class="tag"><div class="text">ERC-721</div></div></div></div>
        </div>
      </div>
    </div>
  </div>

  <div id="team" class="section_team">
    <div class="container services">
      <div data-aos="fade-up" class="header-wrapper">
        <div class="module-eyebrow"><img src="/images/black-icon.svg" loading="lazy" width="10.392416000366211" height="12" alt="" class="icon">
          <div class="black-eyebrow">{{ home.team.eyebrow }}</div>
        </div>
        <h2 class="h2-style black">{{ home.team.heading }}</h2>
        <div class="w-layout-vflex lead-text">
          <p class="body-regular left black">{{ home.team.lead }}</p>
        </div>
      </div>
      <div class="team-flex">
        {% for member in home.team.members %}
        <div data-aos="fade-up" class="team-col"><img src="/images/{{ member.image }}" loading="lazy" alt="{{ member.imageAlt }}" class="team-image">
          <div class="details-wrapper">
            <div class="details-style">
              <div class="name">{{ member.name }}</div>
              <div class="job-role">{{ member.role }}</div>
              <div class="body-regular black left">{{ member.bio }}</div>
            </div>
            <a href="{{ member.linkedin }}" class="linkedin-btn w-inline-block"><img src="/images/linkedin-icon.svg" loading="lazy" width="23.998355865478516" height="24" alt="LinkedIn Icon" class="linkedin-icon"></a>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    <div class="container services">
      <div data-aos="fade-up" class="header-wrapper">
        <div class="module-eyebrow"><img src="/images/black-icon.svg" loading="lazy" width="10.392416000366211" height="12" alt="" class="icon">
          <div class="black-eyebrow">{{ home.team.communityEyebrow }}</div>
        </div>
      </div>
      <div data-aos="fade-up" class="community-wrapper">
        <div id="community-logos-track" class="w-layout-hflex com-wrapper-track">
          <img src="/images/consensys.svg" loading="lazy" width="150.39999389648438" height="32" alt="Consensys Logo" class="com-logo-1">
          <img src="/images/blockchain-mcr_1blockchain-mcr.avif" loading="lazy" width="85.43690490722656" height="88" alt="Blockchain Manchester logo." class="com-logo-2">
          <img src="/images/mcr-digital_1mcr-digital.avif" loading="lazy" width="151.13900756835938" height="37.03468322753906" alt="Manchester Digital logo with blue angle brackets and black text." srcset="/images/mcr-digital_1-p-500.png 500w, /images/mcr-digital_1mcr-digital.avif 1612w" sizes="(max-width: 479px) 100vw, 151px" class="com-logo-2">
          <img src="/images/logo_1.svg" loading="lazy" width="76.06634521484375" height="88" alt="" class="com-logo-2">
          <img src="/images/logo_1logo.png" loading="lazy" width="75.90840148925781" height="88" alt="" class="com-logo-2">
          <img src="/images/northern-blockchain.avif" loading="lazy" width="119" height="51" alt="Northern Blockchain logo." class="com-logo-2">
          <img src="/images/nf-alliance.svg" loading="lazy" width="195" height="22.063228607177734" alt="The Non-Fungible Alliance Logo" class="logo-3">
        </div>
      </div>
    </div>
  </div>

  <div id="blog" class="section_blog">
    <div class="container">
      <div data-aos="fade-up" class="header-and-button">
        <div class="header-wrapper">
          <div class="module-eyebrow"><img src="/images/icon.svg" loading="lazy" width="10.392416000366211" height="12" alt="" class="icon">
            <div class="green-eyebrow">{{ home.blog.eyebrow }}</div>
          </div>
          <h2 class="h2-style">{{ home.blog.heading }}</h2>
          <div class="w-layout-vflex lead-text">
            <p class="body-regular left">{{ home.blog.lead }}</p>
          </div>
        </div>
        <a href="/blog/index.html" class="secondary-button blogs w-button">View More Blogs</a>
      </div>
      <div class="w-layout-hflex blog-grid">
        {% for post in latestPosts %}
        <a data-aos="fade-up" href="{{ post.url }}" class="blog-card w-inline-block">
          <img src="{{ '/images/' + post.coverImage if post.coverImage else '/images/news-img-block-2_1news-img-block-2.avif' }}"
               loading="lazy"
               sizes="(max-width: 900px) 100vw, 900px"
               alt="{{ post.title }}" class="blog-img">
          <div class="blog-content">
            <div class="blog-title">{{ post.title }}</div>
            <div class="body-regular left">{{ post.excerpt }}</div>
          </div>
          <div class="blog-tag-row">
            {% for tag in post.tags %}
            <div class="blog-tag">
              <div class="tag-txt">{{ tag.label }}</div>
            </div>
            {% endfor %}
          </div>
        </a>
        {% else %}
        <p class="body-regular left">No posts yet — check back soon.</p>
        {% endfor %}
      </div>
      <a href="/blog/index.html" class="secondary-button blogs-wide w-button">View More Blogs</a>
    </div>
    <img src="/images/half-blocks-right.png" loading="lazy" data-aos="fade-up" alt="" class="right-half-block blog">
    <img src="/images/half-blocks-left.png" loading="lazy" data-aos="fade-up" alt="" class="left-half-block blog">
  </div>

  <div id="contact" class="section_contact">
    <div class="container contact">
      <div data-aos="fade-up" class="w-layout-vflex contact-col">
        <div class="header-wrapper contact">
          <div class="module-eyebrow"><img src="/images/icon.svg" loading="lazy" width="10.392416000366211" height="12" alt="" class="icon">
            <div class="green-eyebrow">{{ home.contact.eyebrow }}</div>
          </div>
          <h2 class="h2-style">{{ home.contact.heading }}</h2>
          <div class="w-layout-vflex lead-text">
            <p class="body-regular left">{{ home.contact.lead }}</p>
          </div>
        </div>
        <div class="contact-flex">
          <div class="contact-row"><img src="/images/email.svg" loading="lazy" width="24" height="24" alt="" class="email">
            <a href="mailto:{{ home.contact.email }}" class="contact-large">{{ home.contact.email }}</a>
          </div>
        </div>
      </div>
      <div data-aos="fade-up" class="form-wrapper">
        <div class="form-block w-form">
          <form id="contact-form" name="contact-form" data-name="Contact Form" action="https://formspree.io/f/mbdbjzqz" method="POST" accept-charset="UTF-8" class="form">
            <input type="hidden" name="_subject" value="New BlockRocket website enquiry">
            <label for="contact-name" class="input-label">Name</label>
            <input class="field-row-wrapper w-input" maxlength="256" name="name" data-name="Name" data-fs-field placeholder="Your Name" type="text" id="contact-name" required="">
            <span class="form-field-message" data-fs-error="name" aria-live="polite"></span>
            <label for="contact-email" class="input-label">Email</label>
            <input class="field-row-wrapper w-input" maxlength="256" name="email" data-name="Email" data-fs-field placeholder="Your Email" type="email" id="contact-email" required="">
            <span class="form-field-message" data-fs-error="email" aria-live="polite"></span>
            <label for="contact-message" class="input-label">Message</label>
            <textarea required="" placeholder="Your Message" maxlength="5000" id="contact-message" name="message" data-name="Message" data-fs-field class="field-row-wrapper w-input"></textarea>
            <span class="form-field-message" data-fs-error="message" aria-live="polite"></span>
            <button type="submit" data-wait="Please wait..." data-fs-submit-btn class="primary-button wide w-button">Submit</button>
          </form>
          <div class="success-message w-form-done" data-fs-success tabindex="-1" aria-live="polite">
            <div>Thanks. Your message has been sent and we&apos;ll get back to you shortly.</div>
          </div>
          <div class="error-message w-form-fail" data-fs-error tabindex="-1" aria-live="polite">
            <div>Oops! Something went wrong while submitting the form.</div>
          </div>
        </div>
      </div>
    </div>
    <img src="/images/half-blocks-right.png" loading="lazy" data-aos="fade-up" alt="" class="right-half-block contact">
  </div>

  {% include "_partials/footer.njk" %}
  {% include "_partials/scripts.njk" %}
  <script>
  window.formspree = window.formspree || function () {
    (formspree.q = formspree.q || []).push(arguments);
  };
  formspree('initForm', {
    formElement: '#contact-form',
    formId: 'mbdbjzqz'
  });
  </script>
  <script src="https://unpkg.com/@formspree/ajax@1" defer></script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "BlockRocket",
    "url": "{{ site.url }}",
    "logo": "{{ site.url }}/images/logo_2.svg",
    "description": "Expert-led Web3 consultancy based in Manchester. Blockchain strategy, smart contract engineering, and decentralised systems since 2018.",
    "foundingDate": "2018",
    "foundingLocation": "Manchester, UK",
    "email": "{{ home.contact.email }}",
    "sameAs": [
      "https://www.linkedin.com/company/blockrockettech/",
      "https://twitter.com/blockrockettech",
      "https://medium.com/blockrocket",
      "https://github.com/blockrockettech"
    ],
    "founders": [
      {
        "@type": "Person",
        "name": "Andy Gray",
        "url": "https://uk.linkedin.com/in/andrewmgray",
        "jobTitle": "Co-Founder"
      },
      {
        "@type": "Person",
        "name": "James Morgan",
        "url": "https://uk.linkedin.com/in/jamesemorgan",
        "jobTitle": "Co-Founder"
      }
    ]
  }
  </script>
</body>
</html>
