<script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=69de223b8ce59324f86bc3c7" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
<script src="/js/webflow.js" type="text/javascript"></script>
<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {
  AOS.init({
    duration: 800,
    easing: 'ease-out-cubic',
    once: true,
    offset: 100
  });
  const serviceTracks = document.querySelectorAll(
    ".services-swiper .swiper-wrapper, .services-swiper-reverse .swiper-wrapper"
  );
  serviceTracks.forEach(function(track) {
    if (track.dataset.duplicated === "true") return;
    track.innerHTML += track.innerHTML;
    track.dataset.duplicated = "true";
  });
  const logoTrack = document.querySelector(".client-logos-track");
  if (logoTrack && logoTrack.dataset.duplicated !== "true") {
    logoTrack.innerHTML += logoTrack.innerHTML;
    logoTrack.dataset.duplicated = "true";
  }
  const communityTrack = document.querySelector(".com-wrapper-track");
  if (communityTrack && communityTrack.dataset.duplicated !== "true") {
    communityTrack.innerHTML += communityTrack.innerHTML;
    communityTrack.dataset.duplicated = "true";
  }
});
</script>
