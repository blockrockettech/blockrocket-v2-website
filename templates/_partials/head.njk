<style>
.services-swiper,
.services-swiper-reverse {
  overflow: hidden;
  width: 100%;
  position: relative;
  background: transparent;
}
.services-swiper .w-dyn-list,
.services-swiper-reverse .w-dyn-list,
.services-swiper .w-dyn-items,
.services-swiper-reverse .w-dyn-items {
  background: transparent;
}
.services-swiper .swiper-wrapper,
.services-swiper-reverse .swiper-wrapper {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  width: max-content;
  gap: 32px;
  will-change: transform;
}
.services-swiper .swiper-wrapper.is-left {
  animation: services-marquee-left 12s linear infinite;
}
.services-swiper-reverse .swiper-wrapper.is-right {
  animation: services-marquee-right 12s linear infinite;
}
.services-swiper .swiper-slide,
.services-swiper-reverse .swiper-slide {
  flex: 0 0 auto;
  margin: 0;
}
.services-swiper .row-item-text,
.services-swiper-reverse .row-item-text {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  flex: 0 0 auto;
  margin: 0;
}
@keyframes services-marquee-left {
  from { transform: translate3d(0, 0, 0); }
  to   { transform: translate3d(-50%, 0, 0); }
}
@keyframes services-marquee-right {
  from { transform: translate3d(-50%, 0, 0); }
  to   { transform: translate3d(0, 0, 0); }
}
</style>
<link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
<style>
.client-logos {
  overflow: hidden;
  width: 100%;
}
.client-logos-track {
  display: flex;
  width: max-content;
  animation: logos-marquee 20s linear infinite;
  will-change: transform;
}
.client-logos-track > * {
  flex: 0 0 auto;
  margin-right: 40px;
}
@keyframes logos-marquee {
  from { transform: translate3d(0, 0, 0); }
  to   { transform: translate3d(-50%, 0, 0); }
}
.community-wrapper {
  overflow: hidden;
  width: 100%;
}
.com-wrapper-track {
  display: flex;
  width: max-content;
  animation: community-marquee 20s linear infinite;
  will-change: transform;
}
.com-wrapper-track > * {
  flex: 0 0 auto;
  margin-right: 40px;
}
@keyframes community-marquee {
  from { transform: translate3d(0, 0, 0); }
  to   { transform: translate3d(-50%, 0, 0); }
}
</style>
