<meta charset="utf-8">
<title>{{ pageTitle }}</title>
<meta name="description" content="{{ pageDescription }}">
<meta name="robots" content="index, follow">

{# Open Graph #}
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ pageDescription }}">
<meta property="og:image" content="{{ site.url }}/images/br-social.jpg">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:url" content="{{ site.url }}{{ pageUrl or '/' }}">
<meta property="og:site_name" content="BlockRocket">

{# Article-specific (populated in post.njk) #}
{% if ogArticlePublishedTime %}
<meta property="article:published_time" content="{{ ogArticlePublishedTime }}">
<meta property="article:author" content="https://blockrocket.tech">
{% endif %}

{# Twitter / X #}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@blockrockettech">
<meta name="twitter:title" content="{{ pageTitle }}">
<meta name="twitter:description" content="{{ pageDescription }}">
<meta name="twitter:image" content="{{ site.url }}/images/br-social.jpg">

{# Canonical #}
<link rel="canonical" href="{{ site.url }}{{ pageUrl or '/' }}">

<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="/css/normalize.css" rel="stylesheet" type="text/css">
<link href="/css/base.css" rel="stylesheet" type="text/css">
<link href="/css/blockrocket.css" rel="stylesheet" type="text/css">

<link href="https://fonts.googleapis.com" rel="preconnect">
<link href="https://fonts.gstatic.com" rel="preconnect" crossorigin="anonymous">
<script src="https://ajax.googleapis.com/ajax/libs/webfont/1.6.26/webfont.js" type="text/javascript"></script>
<script type="text/javascript">WebFont.load({  google: {    families: ["Zalando Sans:300,400,500,600,700"]  }});</script>

<link href="/images/favicon.jpg" rel="shortcut icon" type="image/x-icon">
<link href="/images/webclip.png" rel="apple-touch-icon">

<style>
.services-swiper,
.services-swiper-reverse {
  overflow: hidden;
  width: 100%;
  position: relative;
  background: transparent;
}
.services-swiper .swiper-wrapper,
.services-swiper-reverse .swiper-wrapper {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  width: max-content;
  gap: 32px;
  will-change: transform;
}
.services-swiper .swiper-wrapper.is-left {
  animation: services-marquee-left 12s linear infinite;
}
.services-swiper-reverse .swiper-wrapper.is-right {
  animation: services-marquee-right 12s linear infinite;
}
.services-swiper .swiper-slide,
.services-swiper-reverse .swiper-slide {
  flex: 0 0 auto;
  margin: 0;
}
.services-swiper .row-item-text,
.services-swiper-reverse .row-item-text {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  flex: 0 0 auto;
  margin: 0;
}
@keyframes services-marquee-left {
  from { transform: translate3d(0, 0, 0); }
  to   { transform: translate3d(-50%, 0, 0); }
}
@keyframes services-marquee-right {
  from { transform: translate3d(-50%, 0, 0); }
  to   { transform: translate3d(0, 0, 0); }
}
</style>

<link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">

<style>
.client-logos {
  overflow: hidden;
  width: 100%;
}
.client-logos-track {
  display: flex;
  width: max-content;
  animation: logos-marquee 20s linear infinite;
  will-change: transform;
}
.client-logos-track > * {
  flex: 0 0 auto;
  margin-right: 40px;
}
@keyframes logos-marquee {
  from { transform: translate3d(0, 0, 0); }
  to   { transform: translate3d(-50%, 0, 0); }
}
.community-wrapper {
  overflow: hidden;
  width: 100%;
}
.com-wrapper-track {
  display: flex;
  width: max-content;
  animation: community-marquee 20s linear infinite;
  will-change: transform;
}
.com-wrapper-track > * {
  flex: 0 0 auto;
  margin-right: 40px;
}
@keyframes community-marquee {
  from { transform: translate3d(0, 0, 0); }
  to   { transform: translate3d(-50%, 0, 0); }
}
</style>
