<!DOCTYPE html>
<html lang="en">
<head>
  {% set pageTitle = "Blog | BlockRocket" %}
  {% set pageDescription = "High-performance blockchain solutions for enterprise and startups. From smart contract auditing to full-stack Web3 engineering, we build production-ready systems." %}
  {% include "_partials/head.njk" %}
</head>
<body class="body">
  {% set isHome = false %}
  {% include "_partials/nav.njk" %}

  <div id="hero" class="section_header">
    <div data-aos="fade-up" class="container blog-header">
      <div data-aos="fade-up" class="header-wrapper">
        <div class="breadcrumb-wrapper">
          <a href="/" class="breadcrumb-link">Home</a><img src="/images/chevron_1.svg" loading="lazy" width="16" height="16" alt="" class="icon_chevron">
          <a href="/blog/index.html" class="breadcrumb-link active-page">Blogs</a>
        </div>
        <h2 class="h2-style">The Intelligence Hub</h2>
        <div class="w-layout-vflex lead-text">
          <p class="body-regular left">Education is at our core. Explore our latest guides and technical deep-dives to help your business stay ahead on-chain.</p>
        </div>
      </div>
    </div>
    <img src="/images/half-blocks-left.png" loading="lazy" data-aos="fade-up" alt="" class="left-half-block blog">
    <img src="/images/half-blocks-right.png" loading="lazy" data-aos="fade-up" alt="" class="right-half-block blog">
  </div>

  {% if featuredPost %}
  <div class="section_featured-blog">
    <div data-aos="fade-up" class="container">
      <a href="{{ featuredPost.url }}" class="featured-blog-card w-inline-block">
        <div class="img-style"{% if featuredPost.coverImage %} style="background-image: url('/images/{{ featuredPost.coverImage }}')"{% endif %}></div>
        <div class="right-container">
          <div class="ft-blog-tag">
            <div class="filter-txt">Featured</div>
          </div>
          <div class="content-wrapper">
            <div class="featured-blog-title">{{ featuredPost.title }}</div>
            <div class="body-large">{{ featuredPost.excerpt }}</div>
            <div class="blog-details-row">
              <div class="read-time"><img src="/images/time.svg" loading="lazy" width="20" height="20" alt="" class="time">
                <div class="details-txt black">{{ featuredPost.readTime }}</div>
              </div>
              <div class="date-published"><img src="/images/calendar.svg" loading="lazy" width="20" height="20" alt="" class="time">
                <div class="details-txt black">{{ featuredPost.date | formatDate }}</div>
              </div>
            </div>
          </div>
          <div class="blog-tag-row">
            {% for tag in featuredPost.tags %}
            <div class="blog-tag dark">
              <div class="tag-txt black">{{ tag.label }}</div>
            </div>
            {% endfor %}
          </div>
        </div>
      </a>
    </div>
  </div>
  {% endif %}

  <div id="services" data-aos="fade-up" class="section_blog-grid">
    <div class="container blog-parent">
      <div data-aos="fade-up" class="header-wrapper blog">
        <h2 class="h2-style black">Recent Blogs</h2>
        <div class="w-layout-vflex lead-text">
          <p class="body-regular left black">Explore our latest thinking on blockchain, identity, and tokenisation.</p>
        </div>
      </div>

      <div data-aos="fade-up" class="tag-filter-row">
        <a href="#" class="blog-filter active w-inline-block" data-filter="all">
          <div class="filter-txt">All</div>
        </a>
        {% for tag in allTags %}
        <a href="#" class="blog-filter w-inline-block" data-filter="{{ tag | lower | replace(' ', '-') }}">
          <div class="filter-txt">{{ tag }}</div>
        </a>
        {% endfor %}
      </div>

      <div data-aos="fade-up" class="card-grid blog" id="blog-grid">
        {% for post in posts %}
        <a data-aos="fade-up" href="{{ post.url }}" class="blog-card dark w-inline-block"
           data-tags="{{ post.tagsCsv }}">
          <img src="{{ '/images/' + post.coverImage if post.coverImage else '/images/news-img-block-2_1news-img-block-2.avif' }}"
               loading="lazy"
               sizes="(max-width: 900px) 100vw, 900px"
               alt="{{ post.title }}" class="blog-img">
          <div class="blog-content">
            <div class="blog-title dark">{{ post.title }}</div>
            <div class="body-regular left black">{{ post.excerpt }}</div>
          </div>
          <div class="blog-tag-row">
            {% for tag in post.tags %}
            <div class="blog-tag dark">
              <div class="tag-txt black">{{ tag.label }}</div>
            </div>
            {% endfor %}
          </div>
        </a>
        {% else %}
        <p class="body-regular left black">No posts yet — check back soon.</p>
        {% endfor %}
      </div>
    </div>
  </div>

  {% include "_partials/footer.njk" %}
  {% include "_partials/scripts.njk" %}

  <script>
  // Client-side tag filtering
  document.addEventListener('DOMContentLoaded', function () {
    const filters = document.querySelectorAll('.blog-filter');
    const cards = document.querySelectorAll('#blog-grid .blog-card');

    filters.forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        const filter = btn.dataset.filter;

        filters.forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');

        cards.forEach(function (card) {
          if (filter === 'all') {
            card.style.display = '';
          } else {
            const tags = (card.dataset.tags || '').split(',');
            card.style.display = tags.some(function (t) {
              return t.trim().replace(/\s+/g, '-') === filter;
            }) ? '' : 'none';
          }
        });
      });
    });
  });
  </script>
</body>
</html>
